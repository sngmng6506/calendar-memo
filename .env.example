# 로컬 개발용 환경변수 예시 — 복사해서 .env 로 쓰세요(.env는 커밋 안 됨)
# Railway에서는 이 값들을 서비스 Variables에 등록합니다.

# Google Cloud Console에서 만든 OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=여기에-클라이언트-ID.apps.googleusercontent.com

# 세션(JWT) 서명용 비밀키 — 길고 무작위한 문자열
JWT_SECRET=change-me-to-a-long-random-string

# Postgres 연결 문자열 (Railway는 Postgres 추가 시 DATABASE_URL 자동 주입)
DATABASE_URL=postgresql://user:pass@localhost:5432/workboard

# 프로덕션에서는 1 (보안 쿠키 활성화). Railway에서 NODE_ENV=production 설정.
NODE_ENV=development
